                ]
            ]
        },
        {
            "block_label": "paragraph_title",
            "block_content": "### 4.1 Why AWQ Helps Accelerate On-Device LLMs",
            "block_bbox": [
                609,
                1189,
                1057,
                1214
            ],
            "block_id": 19,
            "block_order": 12,
            "group_id": 19,
