                ]
            ]
        },
        {
            "block_label": "display_formula",
            "block_content": " $$ \\begin{aligned}\\mathbf{s}^{*}&=\\underset{\\mathbf{s}}{\\arg\\min}\\mathcal{L}(\\mathbf{s})\\\\\\mathcal{L}(\\mathbf{s})&=\\|Q(\\mathbf{W}\\cdot\\mathrm{diag}(\\mathbf{s}))(\\mathrm{diag}(\\mathbf{s})^{-1}\\cdot\\mathbf{X})-\\mathbf{W}\\mathbf{X}\\|\\end{aligned} $$ ",
            "block_bbox": [
                125,
                517,
                541,
                588
            ],
            "block_id": 9,
            "block_order": 2,
            "group_id": 9,
            "block_polygon_points": [
