        {
            "block_label": "text",
            "block_content": "Formally, we want to optimize the following objective:",
            "block_bbox": [
                105,
                475,
                551,
                499
            ],
            "block_id": 8,
            "block_order": 1,
            "group_id": 8,
            "block_polygon_points": [
                [
