        {
            "block_label": "paragraph_title",
            "block_content": "## 4 TINYCHAT: MAPPING AWQ ONTO EDGE PLATFORMS",
            "block_bbox": [
                610,
                711,
                1085,
                766
            ],
            "block_id": 17,
            "block_order": 10,
            "group_id": 17,
            "block_polygon_points": [
                [
                    610.0,
