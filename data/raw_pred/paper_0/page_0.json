        {
            "block_label": "paragraph_title",
            "block_content": "## ABSTRACT",
            "block_bbox": [
                535,
                432,
                657,
                454
            ],
            "block_id": 4,
            "block_order": 4,
            "group_id": 4,
            "block_polygon_points": [
