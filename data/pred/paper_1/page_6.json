        },
        {
            "block_label": "chart",
            "block_content": "<table border=1 style='margin: auto; width: max-content;'>\n  <thead><tr><th style='text-align: center;'></th><th style='text-align: center;'>Quantized Win</th><th style='text-align: center;'>Tie</th><th style='text-align: center;'>Quantized Lost</th></tr></thead>\n  <tbody>\n    <tr><td style='text-align: center;'>RTN</td><td style='text-align: center;'>63</td><td style='text-align: center;'>71</td><td style='text-align: center;'>149</td></tr>\n    <tr><td style='text-align: center;'>GPTQ</td><td style='text-align: center;'>41</td><td style='text-align: center;'>75</td><td style='text-align: center;'>176</td></tr>\n    <tr><td style='text-align: center;'>AWQ</td><td style='text-align: center;'>235</td><td style='text-align: center;'>52</td><td style='text-align: center;'>2211</td></tr>\n  </tbody>\n</table>",
