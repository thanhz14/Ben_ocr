                ],
                [
                    105.0,
                    415.0
                ]
            ]
        },
        {
            "block_label": "text",
            "block_content": "We perform batch size = 1 inference for all LLMs using a fixed prompt length of 4 tokens. We generate 200 tokens for each inference run and calculate the median latency as the final result.",
            "block_bbox": [
                104,
                454,
                583,
                550
            ],
            "block_id": 5,
            "block_order": 1,
            "group_id": 5,
            "block_polygon_points": [
                [
                    104.0,
