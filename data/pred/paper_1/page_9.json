            "block_content": "\n<table border=1 style='margin: auto; word-wrap: break-word;'><tr><td style='text-align: center; word-wrap: break-word;'>Model (Throughput $ \\uparrow $)</td><td style='text-align: center; word-wrap: break-word;'>Precision</td><td style='text-align: center; word-wrap: break-word;'>A100</td><td style='text-align: center; word-wrap: break-word;'>4090</td><td style='text-align: center; word-wrap: break-word;'>Orin</td></tr><tr><td style='text-align: center; word-wrap: break-word;'>VILA-7B</td><td style='text-align: center; word-wrap: break-word;'>FP16</td><td style='text-align: center; word-wrap: break-word;'>81.6</td><td style='text-align: center; word-wrap: break-word;'>58.5</td><td style='text-align: center; word-wrap: break-word;'>11.5</td></tr><tr><td style='text-align: center; word-wrap: break-word;'>VILA-7B-AWQ</td><td style='text-align: center; word-wrap: break-word;'>W4A16</td><td style='text-align: center; word-wrap: break-word;'>155.3</td><td style='text-align: center; word-wrap: break-word;'>168.1</td><td style='text-align: center; word-wrap: break-word;'>35.6</td></tr><tr><td style='text-align: center; word-wrap: break-word;'>VILA-13B</td><td style='text-align: center; word-wrap: break-word;'>FP16</td><td style='text-align: center; word-wrap: break-word;'>48.5</td><td style='text-align: center; word-wrap: break-word;'>OOM</td><td style='text-align: center; word-wrap: break-word;'>6.1</td></tr><tr><td style='text-align: center; word-wrap: break-word;'>VILA-13B-AWQ</td><td style='text-align: center; word-wrap: break-word;'>W4A16</td><td style='text-align: center; word-wrap: break-word;'>102.1</td><td style='text-align: center; word-wrap: break-word;'>99.0</td><td style='text-align: center; word-wrap: break-word;'>17.5</td></tr></table>",
