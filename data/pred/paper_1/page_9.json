        {
            "block_label": "paragraph_title",
            "block_content": "### 5.3 Data Efficiency and Generalization",
            "block_bbox": [
                105,
                889,
                457,
                912
            ],
            "block_id": 14,
            "block_order": 2,
            "group_id": 14,
            "block_polygon_points": [
                [
