        {
            "block_label": "figure_title",
            "block_content": "<div style=\"text-align: center;\">Figure 7. Qualitative results of quantized OpenFlamingo-9B (Awadalla et al., 2023) on COCO captioning dataset (4-shot, INT4-g128 quantization). Our method significantly improves the captioning quality compared to the round-to-nearest (RTN) baseline. We color the text to show the correct or wrong captions.</div>\n",
            "block_bbox": [
                106,
                571,
                1087,
                633
            ],
            "block_id": 15,
            "block_order": null,
            "group_id": 15,
            "block_polygon_points": [
