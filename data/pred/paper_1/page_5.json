        {
            "block_label": "text",
            "block_content": "with 200 tokens only takes 10 ms. Consequently, the generation phase is substantially slower than the context stage, particularly for on-device interactive applications.",
            "block_bbox": [
                104,
                365,
                586,
                437
            ],
            "block_id": 5,
            "block_order": 1,
            "group_id": 5,
            "block_polygon_points": [
